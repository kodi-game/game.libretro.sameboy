msgctxt "Addon Summary"
msgid "Nintendo - Game Boy / Color (SameBoy)"
msgstr "Nintendo - Game Boy / Color (SameBoy)"

msgctxt "Addon Description"
msgid "SameBoy is an open source Gameboy (DMG) and Gameboy Color (CGB) emulator, written in portable C."
msgstr "SameBoy je open-source emulátor Game Boy (DMG) a Game Boy Color (CGB) napsaný v přenositelném C."

